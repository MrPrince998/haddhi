{
  "name": "@haddhi/react",
  "version": "0.1.2",
  "description": "React skeleton loading components generated from rendered UI.",
  "type": "module",
  "homepage": "https://www.npmjs.com/package/@haddhi/react",
  "repository": {
    "type": "git",
    "url": "https://github.com/MrPrince998/haddhi",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/MrPrince998/haddhi/issues"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "keywords": [
    "react",
    "skeleton",
    "loading"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "prepack": "pnpm build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  }
}
